# Local development (Docker Compose Postgres)
DATABASE_URL=postgresql://horizons:horizons@localhost:5435/horizons

# Production (Railway — auto-injected, do not set manually)
# DATABASE_URL is provided by Railway Postgres plugin

# Anthropic API (Phase 5)
# ANTHROPIC_API_KEY=sk-ant-...

# Auth.js (required — generate with: npx auth secret)
AUTH_SECRET=
AUTH_TRUST_HOST=true
